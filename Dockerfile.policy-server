FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY src/ ./src/

RUN pip install --no-cache-dir -e ".[server]"

ENV DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/airiskguard

EXPOSE 8000

CMD ["uvicorn", "airiskguard_gateway.policy_server.main:app", "--host", "0.0.0.0", "--port", "8000"]
